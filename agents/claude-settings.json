{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.git-ai/bin/git-ai checkpoint claude --hook-input stdin",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.git-ai/bin/git-ai checkpoint claude --hook-input stdin",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Edit",
      "Agent(Explore)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "ask": [
      "Bash(gh pr create:*)"
    ],
    "defaultMode": "acceptEdits"
  }
}
